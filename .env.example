# Copy this file to the path used by servermanager.py (default /home/steam/.env,
# or set ENV_FILE) and fill in your own values. Never commit the real .env.
# server.sh sources this file, so these vars drive both the game launch and the
# Telegram alert bot.

# --- Paths ---
GAME_DIR=/home/steam/sandstorm_server
LOG_FILE_PATH=/home/steam/sandstorm_server/Insurgency/Saved/Logs/Insurgency.log
MAPCYCLE_FILE=/home/steam/sandstorm_server/Insurgency/Config/Server/MapCycle.txt

# --- Server identity / network (shared by server.sh and the alert board) ---
SERVER_NAME=My Insurgency Server
MAX_PLAYERS=8
GAME_PORT=27102
QUERY_PORT=27131

# --- RCON ---
# Keep the RCON port CLOSED in the firewall
RCON_IP=127.0.0.1
RCON_PORT=27015
RCON_PASSWORD=changeme-use-a-long-random-password

# --- Steam / GSLT ---
GSLT_TOKEN=
GAMESTATS_TOKEN=
STEAM_API_KEY=

# --- Game alerts (Telegram live board + per-event messages + Grafana metric) ---
# Empty TELEGRAM_* - Telegram disabled. Empty METRICS_FILE - no Prometheus metric.
TELEGRAM_GAME_TOKEN=
TELEGRAM_GAME_CHAT_ID=
BOARD_STATE_FILE=/home/steam/sandstorm_server/board_message_id.txt
METRICS_FILE=/var/lib/node_exporter/iss_players.prom
